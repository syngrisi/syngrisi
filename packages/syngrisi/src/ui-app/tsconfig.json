{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext", "es6", "dom"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
        "@shared/*": ["shared/*"],
        "@hooks/*": ["index2/hooks/*"],
        "@index/*": ["index2/*"],
        "@admin/*": ["admin/*"],
        "@auth/*": ["auth/*"],
        "@asserts/*": ["asserts/*"],
        "@config": ["config.ts"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["index2", "admin", "auth", "shared", "asserts", "config.ts", "ui-app-modules.d.ts"]
}
