{
  "compilerOptions": {
    /* Basic Options */
    "target": "ES2020",
    "module": "es2020",
    /* NOTE: module is "es2020" (not "commonjs") because the current Babel
       build emits ESM (import/export) and package.json has no
       "type": "module" field — this preserves the existing publish format.
       See plans/027-build-tooling-standardize.md for the rationale. */
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",

    /* Strict Type-Checking Options */
    "strict": false,
    /* NOTE: relaxed from the repo's tsc baseline (strict: true) because this
       package's source was untyped legacy JS with no prior type coverage;
       turning full strict mode on here would require substantial rewriting
       for no functional benefit. The goal of this migration is a working tsc
       build with types, not a strictness crusade. */

    /* Module Resolution Options */
    "moduleResolution": "node",
    "esModuleInterop": true,

    /* Advanced Options */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": [
    "tests",
    "dist",
    "coverage",
    "node_modules",
    "vitest.config.js"
  ]
}
