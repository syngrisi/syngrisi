{
  "name": "wdio-syngrisi-cucumber-service",
  "version": "3.15.0",
  "description": "WDIO Service for Syngrisi visual tests using Cucumber",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=22.19.0"
  },
  "np": {
    "releaseDraft": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/syngrisi/syngrisi"
  },
  "bugs": {
    "url": "https://github.com/syngrisi/syngrisi/issues"
  },
  "scripts": {
    "pub": "run-s install:global clean compile; np",
    "build": "run-s clean compile",
    "clean": "rimraf ./dist",
    "compile": "tsc -p ./tsconfig.json",
    "test": "vitest run",
    "install:local": "yarn remove @syngrisi/syngrisi-wdio-sdk && yarn add ../wdio-sdk",
    "install:global": "yarn remove @syngrisi/syngrisi-wdio-sdk && yarn add @syngrisi/syngrisi-wdio-sdk",
    "pkglist": "npx npm-packlist # list of files that will be published in syngrisi package, show the files section"
  },
  "keywords": [
    "wdio-plugin",
    "wdio-service",
    "syngrisi"
  ],
  "author": "Viktar Silakou",
  "license": "MIT",
  "devDependencies": {
    "vitest": "^4.1.9",
    "@types/node": "^26.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "@syngrisi/wdio-sdk": "^3.15.0",
    "@wdio/logger": "^9.18.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "gitHead": "12bfda406cbe5aaccf3f17fdab02a9bd1a9d6343"
}
