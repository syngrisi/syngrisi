{
  "compilerOptions": {
    /* Basic Options */
    "target": "ES2020",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",

    /* Strict Type-Checking Options */
    "strict": false,
    /* NOTE: relaxed from the repo's tsc baseline (strict: true) because this
       package's source was untyped legacy JS with no prior type coverage;
       turning full strict mode on here would require substantial rewriting
       for no functional benefit. The goal of this migration is a working tsc
       build with types, not a strictness crusade. */

    /* Module Resolution Options */
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,

    /* Advanced Options */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "exclude": [
    "tests",
    "dist",
    "coverage",
    "node_modules",
    "vitest.config.js"
  ]
}
